{
  "name": "crash-game",
  "private": true,
  "workspaces": [
    "services/*",
    "packages/*",
    "frontend"
  ],
  "scripts": {
    "docker:up": "docker compose up",
    "docker:down": "docker compose down",
    "docker:prune": "docker compose down -v --rmi all --remove-orphans && docker volume prune -f"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/passport-jwt": "^4.0.1",
    "bun-types": "latest"
  },
  "dependencies": {
    "@nestjs/microservices": "^11.1.23",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/schedule": "^6.1.3",
    "amqp-connection-manager": "^5.0.0",
    "amqplib": "^2.0.1",
    "jwks-rsa": "^4.0.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1"
  }
}
